<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Enable App Sandbox -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Allow read/write access to user-selected files (via open/save dialogs) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- NO network access -->
    <!-- com.apple.security.network.client is intentionally ABSENT -->
    <!-- com.apple.security.network.server is intentionally ABSENT -->
</dict>
</plist>
